{
  "kind": "collectionType",
  "collectionName": "challenge_enrollments",
  "info": {
    "singularName": "challenge-enrollment",
    "pluralName": "challenge-enrollments",
    "displayName": "Challenge Enrollment"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    },
    "challenge": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::challenge.challenge",
      "required": true
    },
    "enrolledAt": { "type": "datetime", "required": true },
    "currentDay": { "type": "integer", "default": 1 },
    "completedAt": { "type": "datetime" },
    "daysCompleted": { "type": "json" }
  }
}